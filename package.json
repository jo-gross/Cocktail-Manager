{
  "name": "cocktail-manager",
  "version": "1.20.6",
  "private": true,
  "description": "Web application for managing cocktail recipes, ingredients, and bar workspaces",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "analyze": "ANALYZE=true next build --webpack",
    "generate:screenshots": "tsx scripts/generate-screenshots.ts",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "start:migrate": "prisma migrate deploy && pnpm start",
    "prepare": "husky"
  },
  "keywords": [
    "cocktails",
    "bar-management",
    "recipes",
    "nextjs"
  ],
  "author": "Johannes Groß",
  "license": "Commons Clause” License Condition v1.0 with AGPL-3.0",
  "dependencies": {
    "@prisma/adapter-pg": "7.5.0",
    "@prisma/client": "7.5.0",
    "@serwist/next": "^9.5.7",
    "bcrypt": "^6.0.0",
    "better-auth": "^1.5.5",
    "browser-image-compression": "^2.0.2",
    "chart.js": "4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "classnames": "^2.5.1",
    "deep-diff": "1.0.2",
    "ejs": "^5.0.1",
    "formik": "2.4.9",
    "framer-motion": "^12.38.0",
    "graph-data-structure": "4.5.0",
    "http-method-enum": "1.0.0",
    "js-levenshtein": "1.1.6",
    "jsonwebtoken": "^9.0.3",
    "jssoup": "0.0.15",
    "keyv": "^5.6.0",
    "lodash": "4.17.23",
    "next": "16.2.1",
    "serwist": "^9.5.7",
    "node-html-parser": "7.1.0",
    "nodemailer": "8.0.4",
    "pdf-lib": "^1.17.1",
    "pg": "^8.20.0",
    "prop-types": "15.8.1",
    "puppeteer-core": "^24.39.1",
    "react": "19.2.4",
    "react-chartjs-2": "5.3.1",
    "react-device-detect": "2.2.3",
    "react-dom": "19.2.4",
    "react-icons": "5.6.0",
    "react-image-crop": "11.0.10",
    "react-markdown": "10.1.0",
    "react-select": "5.10.2",
    "react-three-state-checkbox": "3.0.0",
    "recharts": "3.8.1",
    "rxjs": "7.8.2",
    "use-pull-to-refresh": "^2.4.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.0",
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^6.0.0",
    "@types/deep-diff": "1.0.5",
    "@types/ejs": "^3.1.5",
    "@types/js-levenshtein": "1.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "4.17.24",
    "@types/node": "25.5.0",
    "@types/nodemailer": "7.0.11",
    "@types/pg": "^8.18.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "10.4.27",
    "daisyui": "4.12.24",
    "dotenv": "^17.3.1",
    "eslint": "10.1.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-prisma": "5.0.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "prisma": "7.5.0",
    "tailwindcss": "3.4.19",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
